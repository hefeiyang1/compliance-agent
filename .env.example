# Application Configuration
APP_NAME=ComplianceAgent
APP_VERSION=0.1.0
DEBUG=false
LOG_LEVEL=INFO

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_PREFIX=/api/v1

# Database (PostgreSQL with pgvector)
DATABASE_URL=postgresql://compliance_user:compliance_pass@localhost:5432/compliance_db
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# Redis Cache
REDIS_URL=redis://localhost:6379
REDIS_CACHE_TTL=3600
REDIS_MAX_CONNECTIONS=50

# ChromaDB Vector Database
CHROMADB_HOST=localhost
CHROMADB_PORT=8001
CHROMADB_COLLECTION_NAME=compliance_docs

# Embedding Model Configuration
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
EMBEDDING_DEVICE=cpu
EMBEDDING_BATCH_SIZE=32

# Document Processing
MAX_FILE_SIZE_MB=100
CHUNK_SIZE=512
CHUNK_OVERLAP=128

# Model API Configuration
DEFAULT_MODEL=qwen
MODEL_TIMEOUT=30
MODEL_MAX_RETRIES=3

# Qwen Model (Enterprise Internal)
QWEN_API_KEY=your-qwen-api-key
QWEN_BASE_URL=http://localhost:8000/v1
QWEN_MODEL_NAME=qwen-plus

# ChatGLM Model (Enterprise Internal)
CHATGLM_API_KEY=your-chatglm-api-key
CHATGLM_BASE_URL=http://localhost:8001/v1
CHATGLM_MODEL_NAME=chatglm3

# Tongyi Qianwen (Alibaba Cloud)
TONGYI_API_KEY=your-tongyi-api-key
TONGYI_MODEL_NAME=qwen-plus

# Wenxin Yiyan (Baidu)
WENXIN_API_KEY=your-wenxin-api-key
WENXIN_SECRET_KEY=your-wenxin-secret-key
WENXIN_MODEL_NAME=ernie-bot-4

# OpenAI (Optional)
OPENAI_API_KEY=your-openai-api-key
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL_NAME=gpt-4

# Security
SECRET_KEY=your-secret-key-change-this-in-production-use-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Rate Limiting
RATE_LIMIT_PER_MINUTE=100
RATE_LIMIT_PER_HOUR=1000

# Agent Configuration
AGENT_MAX_STEPS=10
AGENT_TIMEOUT_SECONDS=300
AGENT_QUALITY_THRESHOLD=0.8

# MCP Tool Gateway
MCP_TIMEOUT_SECONDS=30
MCP_MAX_RETRIES=3
MCP_BACKOFF_MULTIPLIER=2
